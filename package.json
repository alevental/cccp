{
  "name": "@alevental/cccp",
  "version": "0.17.2",
  "description": "Claude Code and Cmux Pipeline Reagent — deterministic YAML-based pipeline orchestration",
  "type": "module",
  "bin": {
    "cccp": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples/*.yaml",
    "examples/agents",
    "examples/autoresearch-artifacts",
    ".claude/skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^14.0.0",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.0.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
